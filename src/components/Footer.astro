---
const year = new Date().getFullYear();

const socials = [
	{ href: 'https://github.com/domindez', label: 'GitHub' },
	{ href: 'https://wa.me/34660882876', label: 'WhatsApp' },
	{ href: 'mailto:info@domindez.com', label: 'Email' },
];
---

<footer class='site-footer' itemscope itemtype='https://schema.org/Organization' aria-label='Información del estudio'>
	<meta itemprop='name' content='Domindez Studio' />
	<meta itemprop='url' content='https://domindez.com' />
	<meta itemprop='logo' content='https://domindez.com/favicon.svg' />
	<meta itemprop='email' content='info@domindez.com' />
	<meta itemprop='telephone' content='+34-660-88-28-76' />
	<meta itemprop='description' content='Estudio de diseño y desarrollo web a medida desde Málaga, España.' />
	<link itemprop='sameAs' href='https://github.com/domindez' />

	<div itemprop='address' itemscope itemtype='https://schema.org/PostalAddress' style='display:none'>
		<meta itemprop='streetAddress' content='Málaga' />
		<meta itemprop='addressLocality' content='Málaga' />
		<meta itemprop='addressRegion' content='Málaga' />
		<meta itemprop='postalCode' content='29001' />
		<meta itemprop='addressCountry' content='ES' />
	</div>

	<div class='container'>
		<div class='footer-cta' data-reveal>
			<p class='eyebrow'><span class='dot'></span> ¿Listo para empezar?</p>
			<a href='#contact' class='footer-cta__link'>
				<span class='serif'>Hablemos</span>
				<svg
					width='48'
					height='48'
					viewBox='0 0 24 24'
					fill='none'
					stroke='currentColor'
					stroke-width='1.5'
					stroke-linecap='square'
					aria-hidden='true'
				>
					<path d='M7 17L17 7M17 7H8M17 7V16'></path>
				</svg>
			</a>
		</div>

		<div class='wordmark' aria-hidden='true'>
			<span>DOMINDEZ</span>
			<span class='wordmark__line'>STUDIO</span>
		</div>

		<div class='footer-grid'>
			<div class='footer-col' itemprop='address' itemscope itemtype='https://schema.org/PostalAddress'>
				<p class='footer-label'>Estudio</p>
				<p>
					<span itemprop='streetAddress'>Málaga</span>,
					<span itemprop='addressCountry'>España</span>
				</p>
				<p>
					Diseño y desarrollo web a medida.<br />
					Atendemos clientes en toda España, Europa y LATAM.
				</p>
			</div>
			<div class='footer-col'>
				<p class='footer-label'>Contacto</p>
				<a href='mailto:info@domindez.com' class='footer-link' itemprop='email'>info@domindez.com</a>
				<a href='tel:+34660882876' class='footer-link' itemprop='telephone'>+34 660 88 28 76</a>
			</div>
			<div class='footer-col'>
				<p class='footer-label'>Sígueme</p>
				<div class='footer-socials'>
					{
						socials.map((social) => (
							<a href={social.href} class='footer-link' target='_blank' rel='noopener nofollow'>
								{social.label} ↗
							</a>
						))
					}
				</div>
			</div>
			<nav class='footer-col' aria-label='Navegación del sitio'>
				<p class='footer-label'>Navegación</p>
				<a href='#services' class='footer-link'>Servicios</a>
				<a href='#work' class='footer-link'>Trabajo</a>
				<a href='#process' class='footer-link'>Proceso</a>
				<a href='#contact' class='footer-link'>Contacto</a>
			</nav>
		</div>

		<div class='footer-bottom'>
			<p>© {year} Domindez Studio. Todos los derechos reservados.</p>
			<nav class='footer-legal' aria-label='Enlaces legales'>
				<a href='/aviso-legal' class='footer-link footer-link--small'>Aviso legal</a>
				<a href='/politica-privacidad' class='footer-link footer-link--small'>Privacidad</a>
				<a href='/politica-cookies' class='footer-link footer-link--small'>Cookies</a>
			</nav>
			<p class='mono'>Hecho con código, café y cariño · Málaga, ES</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		padding-block: var(--section-y) 2rem;
		background: var(--bg);
		border-top: 1px solid var(--border);
		overflow: hidden;
	}

	.footer-cta {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-bottom: 4rem;
	}

	.footer-cta__link {
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		font-size: clamp(3rem, 8vw, 6rem);
		font-weight: 500;
		letter-spacing: -0.04em;
		line-height: 0.9;
		color: var(--fg);
		transition: color 0.4s var(--ease-out);
		width: fit-content;
	}

	.footer-cta__link .serif {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 400;
	}

	.footer-cta__link:hover {
		color: var(--accent);
	}

	.footer-cta__link svg {
		transition: transform 0.5s var(--ease-spring);
	}

	.footer-cta__link:hover svg {
		transform: translate(8px, -8px);
	}

	.wordmark {
		display: block;
		font-family: var(--font-sans);
		font-size: clamp(3.5rem, 21vw, 17rem);
		font-weight: 500;
		letter-spacing: -0.05em;
		line-height: 0.85;
		color: var(--fg-faint);
		margin-block: 2rem 4rem;
		pointer-events: none;
		user-select: none;
		white-space: nowrap;
	}

	.wordmark__line {
		display: block;
	}

	.wordmark span:last-child {
		color: var(--accent);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2rem;
		padding-block: 3rem;
		border-top: 1px solid var(--border);
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.footer-label {
		font-family: var(--font-mono);
		font-size: var(--fs-100);
		text-transform: uppercase;
		letter-spacing: 0.16em;
		color: var(--fg-mute);
		margin-bottom: 0.5rem;
	}

	.footer-link {
		display: inline-block;
		color: var(--fg-dim);
		font-size: var(--fs-200);
		transition: color 0.3s var(--ease-out), transform 0.3s var(--ease-out);
		width: fit-content;
	}

	.footer-link:hover {
		color: var(--accent);
		transform: translateX(4px);
	}

	.footer-link--small {
		font-size: var(--fs-100);
	}

	.footer-socials {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 1rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
		font-size: var(--fs-100);
		color: var(--fg-mute);
	}

	.footer-legal {
		display: flex;
		gap: 1.25rem;
		flex-wrap: wrap;
	}

	.mono {
		font-family: var(--font-mono);
	}

	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}

		.footer-bottom {
			flex-direction: column;
			gap: 0.75rem;
			text-align: center;
		}
	}
</style>
