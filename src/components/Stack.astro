---
import { stack } from '../data/content';

const grouped = stack.reduce(
	(acc, item) => {
		(acc[item.category] = acc[item.category] || []).push(item.name);
		return acc;
	},
	{} as Record<string, string[]>,
);
---

<section class='stack section' id='stack'>
	<div class='container'>
		<header class='section-head' data-reveal>
			<p class='eyebrow'><span class='dot'></span> Stack</p>
			<h2 class='section-title'>
				Las <em class='serif-italic'>herramientas</em><br />
				que dominamos.
			</h2>
			<p class='section-lede'>
				Trabajamos con el mejor stack para cada proyecto, sin atarnos a una sola tecnología.
				Lo importante es el resultado, no la herramienta.
			</p>
		</header>

		<div class='stack__marquee' data-marquee data-direction='left' data-speed='50'>
			<div class='stack__track' data-marquee-track>
				{
					stack.concat(stack).map((item) => (
						<div class='stack__chip'>
							<span class='stack__chip-name'>{item.name}</span>
							<span class='stack__chip-cat'>{item.category}</span>
						</div>
					))
				}
			</div>
		</div>

		<div class='stack__groups' data-reveal-stagger>
			{
				Object.entries(grouped).map(([category, items]) => (
					<div class='stack__group'>
						<p class='stack__group-label'>{category}</p>
						<ul>
							{items.map((item) => (
								<li>
									<span class='stack__group-dot' />
									{item}
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.stack {
		background: var(--bg-2);
		border-block: 1px solid var(--border);
	}

	.serif-italic {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 400;
		color: var(--accent);
	}

	.stack__marquee {
		position: relative;
		overflow: hidden;
		padding-block: 2rem;
		border-block: 1px solid var(--border);
		margin-bottom: 4rem;
		mask-image: linear-gradient(
			to right,
			transparent 0%,
			black 8%,
			black 92%,
			transparent 100%
		);
	}

	.stack__track {
		display: inline-flex;
		gap: 0.75rem;
		align-items: center;
		will-change: transform;
		padding-left: 0.75rem;
	}

	.stack__chip {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.75rem 1.25rem;
		background: var(--bg-3);
		border: 1px solid var(--border);
		border-radius: var(--radius-pill);
		font-size: var(--fs-300);
		font-weight: 500;
		white-space: nowrap;
		transition: all 0.3s var(--ease-out);
	}

	.stack__chip:hover {
		border-color: var(--accent);
		background: var(--accent-dim);
		color: var(--accent);
	}

	.stack__chip-cat {
		font-family: var(--font-mono);
		font-size: var(--fs-100);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--fg-mute);
	}

	.stack__chip:hover .stack__chip-cat {
		color: var(--accent);
	}

	.stack__groups {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 2.5rem;
	}

	.stack__group {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.stack__group-label {
		font-family: var(--font-mono);
		font-size: var(--fs-100);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent);
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--border);
	}

	.stack__group ul {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.stack__group li {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: var(--fs-200);
		color: var(--fg-dim);
		transition: color 0.3s var(--ease-out);
	}

	.stack__group li:hover {
		color: var(--fg);
	}

	.stack__group-dot {
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: var(--fg-faint);
		transition: background 0.3s var(--ease-out);
	}

	.stack__group li:hover .stack__group-dot {
		background: var(--accent);
	}

	@media (max-width: 1000px) {
		.stack__groups {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 700px) {
		.stack__groups {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 450px) {
		.stack__groups {
			grid-template-columns: 1fr;
		}
	}
</style>
