---
import { services } from '../data/content';
---

<section class='services section' id='services'>
	<div class='container'>
		<header class='section-head' data-reveal>
			<p class='eyebrow'><span class='dot'></span> Servicios</p>
			<h2 class='section-title'>
				Lo que <em class='serif-italic'>hacemos</em>,<br />
				y lo hacemos bien.
			</h2>
			<p class='section-lede'>
				Desde la primera línea de código hasta el último pixel. Cubrimos todo el ciclo de
				vida de un proyecto digital con un equipo senior y atención al detalle.
			</p>
		</header>

		<div class='bento' data-reveal-stagger>
			{
				services.map((service, i) => (
					<article class={`bento__cell ${i === 0 ? 'bento__cell--featured' : ''}`}>
						<div class='bento__head'>
							<span class='bento__num'>{String(i + 1).padStart(2, '0')}</span>
							<h3 class='bento__title'>{service.title}</h3>
						</div>
						<p class='bento__desc'>{service.description}</p>
						<ul class='bento__items'>
							{service.items.map((item) => (
								<li>
									<span class='bento__dot' />
									{item}
								</li>
							))}
						</ul>
						<div class='bento__bg' aria-hidden='true' />
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.services {
		background: var(--bg);
		border-top: 1px solid var(--border);
	}

	.bento {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		grid-auto-rows: minmax(240px, auto);
		gap: 1rem;
	}

	.bento__cell {
		position: relative;
		grid-column: span 1;
		padding: 1.75rem;
		background: var(--bg-2);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		transition:
			border-color 0.4s var(--ease-out),
			transform 0.5s var(--ease-out),
			background 0.4s var(--ease-out);
		isolation: isolate;
		min-height: 280px;
	}

	.bento__cell--featured {
		grid-column: span 2;
		grid-row: span 2;
		background: var(--bg-elev);
		padding: 2.25rem;
		min-height: 100%;
	}

	.bento__cell:hover {
		border-color: var(--border-accent);
		transform: translateY(-4px);
	}

	.bento__head {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.bento__num {
		font-family: var(--font-mono);
		font-size: var(--fs-100);
		color: var(--accent);
		letter-spacing: 0.16em;
	}

	.bento__title {
		font-size: var(--fs-500);
		font-weight: 500;
		letter-spacing: -0.02em;
	}

	.bento__cell--featured .bento__title {
		font-size: var(--fs-700);
	}

	.bento__desc {
		font-size: var(--fs-300);
		color: var(--fg-dim);
		line-height: 1.5;
	}

	.bento__cell--featured .bento__desc {
		font-size: var(--fs-400);
		max-width: 45ch;
	}

	.bento__items {
		margin-top: auto;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.bento__items li {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.4rem 0.8rem;
		background: var(--bg-3);
		border: 1px solid var(--border);
		border-radius: var(--radius-pill);
		font-size: var(--fs-100);
		color: var(--fg-dim);
		font-family: var(--font-mono);
	}

	.bento__cell--featured .bento__items li {
		background: rgba(0, 0, 0, 0.25);
	}

	.bento__dot {
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: var(--accent);
	}

	.bento__bg {
		position: absolute;
		inset: -50% -20% auto auto;
		width: 60%;
		aspect-ratio: 1;
		background: radial-gradient(circle, var(--accent-dim) 0%, transparent 70%);
		filter: blur(40px);
		z-index: -1;
		opacity: 0;
		transition: opacity 0.6s var(--ease-out);
	}

	.bento__cell:hover .bento__bg {
		opacity: 1;
	}

	@media (max-width: 1100px) {
		.bento {
			grid-template-columns: repeat(2, 1fr);
		}

		.bento__cell,
		.bento__cell--featured {
			grid-column: span 1;
			grid-row: auto;
			min-height: 260px;
		}
	}

	@media (max-width: 600px) {
		.bento {
			grid-template-columns: 1fr;
		}

		.bento__cell {
			min-height: 220px;
		}
	}
</style>
