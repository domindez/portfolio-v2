---
import { Image } from 'astro:assets';

const clients: { slug: string; name: string }[] = [
	{ slug: 'gottan', name: 'Gottan Grill' },
	{ slug: 'bsmash', name: 'BSmash' },
	{ slug: 'dak', name: 'Dak Burger' },
	{ slug: 'masai', name: 'Masai' },
	{ slug: 'lucky', name: 'Lucky' },
	{ slug: 'unter', name: 'Unter' },
	{ slug: 'iturrialde', name: 'Iturrialde' },
	{ slug: 'vermu', name: 'Vermú' },
	{ slug: 'amar', name: 'Amar' },
	{ slug: 'arancaes', name: 'Arancaes' },
	{ slug: 'cafe-plaza', name: 'Café Plaza' },
	{ slug: 'casita-abuela', name: 'Casita de la Abuela' },
	{ slug: 'dorado', name: 'Dorado' },
	{ slug: 'la-emperatriz', name: 'La Emperatriz' },
	{ slug: 'la-mexicana', name: 'La Mexicana' },
	{ slug: 'mediterraneo', name: 'Mediterráneo' },
	{ slug: 'meson-santiso', name: 'Mesón Santiso' },
	{ slug: 'premier2', name: 'Premier' },
	{ slug: 'shanao', name: 'Shanao' },
	{ slug: 'Tabanco', name: 'Tabanco' },
	{ slug: 'the-corner', name: 'The Corner' },
	{ slug: 'victoria', name: 'Victoria' },
	{ slug: 'can-boleta', name: 'Can Boleta' },
];
---

<section class='clients'>
	<div class='container'>
		<header class='section-head' data-reveal>
			<p class='eyebrow'><span class='dot'></span> Confían en nosotros</p>
			<h2 class='section-title'>
				Más de <em class='serif-italic'>250 clientes</em><br />
				que vuelven.
			</h2>
			<p class='section-lede'>
				Restaurantes, hoteles, startups, freelancers, profesionales. Trabajamos con quien
				valora el detalle.
			</p>
		</header>
	</div>

	<div class='clients__marquee' data-marquee data-direction='left' data-speed='45' aria-label='Logos de clientes de Domindez Studio'>
		<div class='clients__track' data-marquee-track>
			{
				clients.concat(clients).map((client) => (
					<div class='clients__item' title={`${client.name} — cliente de Domindez Studio`}>
						<Image
							loading='lazy'
							decoding='async'
							width={200}
							height={200}
							src={`/customers-logos/${client.slug}.webp`}
							alt={`Logo de ${client.name}, cliente de Domindez Studio`}
						/>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.clients {
		padding-block: 5rem 4rem;
		background: var(--bg);
		overflow: hidden;
	}

	.serif-italic {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 400;
		color: var(--accent);
	}

	.clients__marquee {
		position: relative;
		overflow: hidden;
		margin-top: 3rem;
		mask-image: linear-gradient(
			to right,
			transparent 0%,
			black 5%,
			black 95%,
			transparent 100%
		);
	}

	.clients__track {
		display: inline-flex;
		gap: 1rem;
		align-items: center;
		padding-left: 1rem;
		will-change: transform;
	}

	.clients__item {
		flex-shrink: 0;
		width: 180px;
		height: 120px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem;
		background: var(--bg-2);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		transition:
			border-color 0.3s var(--ease-out),
			background 0.3s var(--ease-out);
	}

	.clients__item:hover {
		border-color: var(--border-strong);
		background: var(--bg-3);
	}

	.clients__item img {
		width: 100%;
		height: 100%;
		min-width: 0;
		min-height: 0;
		object-fit: contain;
		filter: grayscale(1) brightness(1.4);
		opacity: 0.6;
		transition: all 0.3s var(--ease-out);
	}

	.clients__item:hover img {
		filter: grayscale(0) brightness(1);
		opacity: 1;
	}

	@media (max-width: 600px) {
		.clients__item {
			width: 130px;
			height: 90px;
			padding: 0.5rem;
		}
	}
</style>
