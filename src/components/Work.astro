---
import { Image } from 'astro:assets';
import { works } from '../data/content';

const featured = works.slice(0, 3);
const rest = works.slice(3);
const totalProjects = works.length + 24; // Some are confidential / private
---

<section class='work section' id='work'>
	<div class='container'>
		<header class='section-head' data-reveal>
			<p class='eyebrow'><span class='dot'></span> Trabajo seleccionado</p>
			<h2 class='section-title'>
				Algunos <em class='serif-italic'>proyectos</em>,<br />
				de más de {totalProjects} que hemos construido.
			</h2>
			<p class='section-lede'>
				Webs, plataformas y experiencias que hemos diseñado y desarrollado. Cada proyecto es
				único, cada cliente tiene un objetivo distinto, y todos comparten algo: están hechos
				para funcionar.
			</p>
		</header>

		<div class='work__featured'>
			{
				featured.map((work, i) => (
					<article class='case' data-reveal>
						<a href={work.link} target='_blank' rel='noopener' class='case__link'>
							<div class='case__media'>
								<div class='case__media-inner'>
									<Image
										src={work.img}
										alt={work.title}
										width={1200}
										height={750}
										loading={i === 0 ? 'eager' : 'lazy'}
									/>
								</div>
								<div class='case__overlay'>
									<span class='case__visit'>Visitar proyecto ↗</span>
								</div>
							</div>
							<div class='case__body'>
								<div class='case__meta'>
									<span class='case__num'>{String(i + 1).padStart(2, '0')}</span>
									<span class='case__cat'>{work.category}</span>
									<span class='case__year'>{work.year}</span>
								</div>
								<h3 class='case__title'>{work.title}</h3>
								<p class='case__desc'>{work.description}</p>
								<ul class='case__stack'>
									{work.stack.map((tech) => (
										<li class='tag'>{tech}</li>
									))}
								</ul>
							</div>
						</a>
					</article>
				))
			}
		</div>

		<div class='work__rest' data-reveal-stagger>
			{
				rest.map((work, i) => (
					<article class='work-card'>
						<a href={work.link} target='_blank' rel='noopener' class='work-card__link'>
							<div class='work-card__media'>
								<Image
									src={work.img}
									alt={work.title}
									width={600}
									height={400}
									loading='lazy'
								/>
								<span class='work-card__num'>{String(i + 4).padStart(2, '0')}</span>
							</div>
							<div class='work-card__body'>
								<div class='work-card__head'>
									<h3 class='work-card__title'>{work.title}</h3>
									<span class='work-card__cat'>{work.category}</span>
								</div>
								<p class='work-card__desc'>{work.description}</p>
							</div>
						</a>
					</article>
				))
			}
		</div>

		<p class='work__more' data-reveal>
			<span class='work__more-line'></span>
			<span>Y más de <strong>{totalProjects - works.length}</strong> proyectos adicionales en cartera</span>
			<span class='work__more-line'></span>
		</p>
	</div>
</section>

<style>
	.work {
		background: var(--bg);
		border-top: 1px solid var(--border);
	}

	.serif-italic {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 400;
		color: var(--accent);
	}

	/* Featured cases */
	.work__featured {
		display: flex;
		flex-direction: column;
		gap: 6rem;
		margin-bottom: 6rem;
	}

	.case {
		position: relative;
	}

	.case__link {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 3rem;
		align-items: center;
	}

	.case:nth-child(even) .case__link {
		grid-template-columns: 1fr 1.5fr;
	}

	.case:nth-child(even) .case__media {
		order: 2;
	}

	.case__media {
		position: relative;
		aspect-ratio: 16 / 10;
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--bg-2);
		border: 1px solid var(--border);
		padding: 1.5rem;
	}

	.case__media-inner {
		position: relative;
		width: 100%;
		height: 100%;
		overflow: hidden;
		border-radius: var(--radius);
		background: var(--bg-3);
		transition: transform 0.8s var(--ease-out);
	}

	.case__media-inner img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		transition: transform 0.8s var(--ease-out);
	}

	.case__link:hover .case__media-inner img {
		transform: scale(1.03);
	}

	.case__overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, transparent 0%, rgba(10, 10, 10, 0.85) 100%);
		display: grid;
		place-items: center;
		opacity: 0;
		transition: opacity 0.4s var(--ease-out);
		border-radius: var(--radius);
	}

	.case__link:hover .case__overlay {
		opacity: 1;
	}

	.case__visit {
		font-family: var(--font-mono);
		font-size: var(--fs-200);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--bg);
		background: var(--accent);
		padding: 0.75rem 1.25rem;
		border-radius: var(--radius-pill);
		transform: translateY(8px);
		transition: transform 0.4s var(--ease-out);
	}

	.case__link:hover .case__visit {
		transform: translateY(0);
	}

	.case__body {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.case__meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-family: var(--font-mono);
		font-size: var(--fs-100);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--fg-mute);
	}

	.case__num {
		color: var(--accent);
		font-weight: 500;
	}

	.case__title {
		font-size: clamp(2rem, 4vw, 3.5rem);
		font-weight: 500;
		letter-spacing: -0.03em;
		line-height: 0.95;
	}

	.case__desc {
		font-size: var(--fs-300);
		color: var(--fg-dim);
		line-height: 1.5;
		max-width: 45ch;
	}

	.case__stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	/* Rest grid */
	.work__rest {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
	}

	.work-card {
		position: relative;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--bg-2);
		transition:
			border-color 0.4s var(--ease-out),
			transform 0.5s var(--ease-out);
	}

	.work-card:hover {
		border-color: var(--border-accent);
		transform: translateY(-4px);
	}

	.work-card__link {
		display: flex;
		flex-direction: column;
	}

	.work-card__media {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: var(--bg-3);
		padding: 0.75rem;
	}

	.work-card__media img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		border-radius: var(--radius-sm);
		transition: transform 0.6s var(--ease-out);
	}

	.work-card:hover .work-card__media img {
		transform: scale(1.03);
	}

	.work-card__num {
		position: absolute;
		top: 1rem;
		right: 1rem;
		font-family: var(--font-mono);
		font-size: var(--fs-100);
		letter-spacing: 0.12em;
		color: var(--fg);
		background: rgba(0, 0, 0, 0.75);
		backdrop-filter: blur(8px);
		padding: 0.3rem 0.6rem;
		border-radius: var(--radius-pill);
	}

	.work-card__body {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.work-card__head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 0.5rem;
	}

	.work-card__title {
		font-size: var(--fs-400);
		font-weight: 500;
		letter-spacing: -0.02em;
	}

	.work-card__cat {
		font-family: var(--font-mono);
		font-size: var(--fs-100);
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--fg-mute);
		white-space: nowrap;
	}

	.work-card__desc {
		font-size: var(--fs-100);
		color: var(--fg-dim);
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.work__more {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		margin-top: 5rem;
		font-family: var(--font-mono);
		font-size: var(--fs-100);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--fg-mute);
	}

	.work__more strong {
		color: var(--accent);
		font-weight: 500;
	}

	.work__more-line {
		flex: 1;
		max-width: 200px;
		height: 1px;
		background: var(--border);
	}

	@media (max-width: 1200px) {
		.work__rest {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 900px) {
		.case__link,
		.case:nth-child(even) .case__link {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.case:nth-child(even) .case__media {
			order: 0;
		}

		.work__featured {
			gap: 4rem;
			margin-bottom: 4rem;
		}

		.work__rest {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.work__rest {
			grid-template-columns: 1fr;
		}

		.work__more {
			flex-direction: column;
			gap: 1rem;
			text-align: center;
		}

		.work__more-line {
			width: 100%;
			max-width: 200px;
		}
	}
</style>
