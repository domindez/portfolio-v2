---
import '@fontsource-variable/space-grotesk/wght.css';
import '@fontsource-variable/jetbrains-mono/wght.css';
import '@fontsource/instrument-serif/400.css';
import '@fontsource/instrument-serif/400-italic.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Preloader from '../components/Preloader.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Domindez Studio — Diseño y desarrollo web a medida',
	description = 'Estudio de diseño y desarrollo web. Creamos webs a medida, rápidas y con identidad para marcas que quieren destacar.',
} = Astro.props as Props;
---

<!doctype html>
<html lang='es'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1, viewport-fit=cover' />
		<meta name='theme-color' content='#0a0a0a' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<meta name='generator' content={Astro.generator} />

		<title>{title}</title>
		<meta name='description' content={description} />
		<meta
			name='keywords'
			content='diseño web, desarrollo web, agencia web, portfolio, freelancer, astro, react, next, domindez'
		/>
		<meta name='robots' content='index, follow' />
		<link rel='canonical' href='https://domindez.com' />

		<!-- Open Graph -->
		<meta property='og:title' content={title} />
		<meta property='og:description' content={description} />
		<meta property='og:type' content='website' />
		<meta property='og:url' content='https://domindez.com' />
		<meta property='og:image' content='https://domindez.com/og-image.jpg' />

		<!-- Twitter -->
		<meta name='twitter:card' content='summary_large_image' />
		<meta name='twitter:title' content={title} />
		<meta name='twitter:description' content={description} />
		<meta name='twitter:image' content='https://domindez.com/og-image.jpg' />

		<!-- GTM head -->
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
		</script>
		<script is:inline>
			;(function (w, d, s, l, i) {
				w[l] = w[l] || [];
				w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
				var f = d.getElementsByTagName(s)[0],
					j = d.createElement(s),
					dl = l != 'dataLayer' ? '&l=' + l : '';
				j.async = true;
				j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
				f.parentNode.insertBefore(j, f);
			})(window, document, 'script', 'dataLayer', 'GTM-TSJPBNVN');
		</script>
	</head>
	<body>
		<!-- GTM body -->
		<noscript
			><iframe
				src='https://www.googletagmanager.com/ns.html?id=GTM-5LF986KH'
				height='0'
				width='0'
				style='display:none;visibility:hidden'></iframe></noscript
		>

		<Preloader />

		<div class='grain' aria-hidden='true'></div>

		<Header />

		<main id='main'>
			<slot />
		</main>

		<Footer />

		<script>
			import { initLenis } from '../scripts/lenis';
			import { initCursor, initMagnetic } from '../scripts/cursor';
			import { initReveal, initCounters, initMarquee } from '../scripts/reveal';

			document.addEventListener('DOMContentLoaded', () => {
				initLenis();
				initCursor();
				initReveal();
				initCounters();
				initMarquee();
				initMagnetic();
			});
		</script>
	</body>
</html>
